{
    "semi": true,
    "singleQuote": false,
    "tabWidth": 2,
    "printWidth": 80,
    "trailingComma": "es5",
    "arrowParens": "always",
    "bracketSpacing": true,
    "bracketSameLine": false,
    "useTabs": false,
    "embeddedLanguageFormatting": "auto",
    "plugins": ["prettier-plugin-tailwindcss"]
  }